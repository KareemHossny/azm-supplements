# Supabase — required for database, auth, and storage
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin credentials (create via Supabase dashboard or SQL)
# Run the migration in supabase/migrations/0001_init.sql first.
# Then create an admin user:
#   1. Go to Supabase > Authentication > Users > Add user
#   2. Insert into admins (user_id, name, role) VALUES ('<auth_user_id>', 'Admin Name', 'super_admin');
